{
  "name": "lab-pdf-view-react-native",
  "version": "0.2.9",
  "description": "Lab report layout engine — renders a report JSON/template into React elements (web/Electron) or a static HTML string (React Native via WebView/expo-print).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js",
      "require": "./dist/native.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "expo-file-system": ">=18",
    "expo-print": ">=12",
    "react": ">=18",
    "react-native": ">=0.70",
    "react-native-webview": ">=13",
    "react-test-renderer": ">=18"
  },
  "peerDependenciesMeta": {
    "expo-file-system": {
      "optional": true
    },
    "expo-print": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    },
    "react-test-renderer": {
      "optional": true
    }
  },
  "dependencies": {
    "jsbarcode": "^3.12.3",
    "lodash": "^4.17.21",
    "pdf-lib": "^1.17.1",
    "qrcode-generator": "^2.0.4",
    "qrcode.react": "^4.2.0",
    "react-barcode": "^1.6.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.13",
    "@types/react": "^19.1.1",
    "@types/react-test-renderer": "^19.1.0",
    "expo-file-system": "^19.0.23",
    "expo-print": "^57.0.1",
    "react": "^19.1.1",
    "react-native": "^0.86.0",
    "react-native-webview": "^14.0.1",
    "react-test-renderer": "^19.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
